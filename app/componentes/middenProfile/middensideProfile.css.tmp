.bgfoto {
  width: 200px;
  height: 200px;
  border-radius: 50%;
  background: url(/images/BackgroundAvatar.jpg)
    no-repeat center center / cover;
  margin: 0;
  border: var(--primary-color) 5px solid;
  box-shadow: 0 0 30px 2px rgba(255, 149, 62, 0.4);
  transition: transform 0.3s ease;
}

.bgfoto:hover {
  transform: scale(1.05);
}
